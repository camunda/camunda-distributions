{
  "name": "camunda-8.10-e2e-tests-lightweight",
  "version": "1.0.0",
  "description": "End-to-end tests for the Camunda 8.10 lightweight Docker Compose distribution",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report": "npx playwright show-report",
    "postinstall": "node -e \"const fs=require(\\\"fs\\\"),p=require(\\\"path\\\");const t=p.resolve(\\\"node_modules/@camunda/e2e-test-suite/resources\\\");try{fs.symlinkSync(t,\\\"resources\\\",\\\"junction\\\")}catch(e){if(e.code===\\\"EEXIST\\\")process.exit(0);try{fs.cpSync(t,\\\"resources\\\",{recursive:true})}catch(e2){if(e2.code!==\\\"EEXIST\\\")throw e2}}\""
  },
  "keywords": [
    "camunda",
    "e2e",
    "playwright"
  ],
  "author": "",
  "license": "Apache-2.0",
  "devDependencies": {
    "@camunda/e2e-test-suite": "0.0.849",
    "@playwright/test": "^1.61.1",
    "@types/node": "^18.0.0",
    "dotenv": "^16.5.0",
    "zeebe-node": "^8.3.2"
  }
}
